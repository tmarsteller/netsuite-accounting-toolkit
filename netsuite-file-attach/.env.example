# NetSuite Token-Based Authentication (TBA) credentials.
# Copy this file to .env and fill in the values. NEVER commit the real .env.
#
# Where these come from:
#   NS_ACCOUNT_ID      Setup > Company > Company Information > Account ID
#                      (e.g. 1234567, or 1234567-sb1 for a sandbox)
#   NS_CONSUMER_KEY    Integration record (Setup > Integration > Manage Integrations)
#   NS_CONSUMER_SECRET shown ONCE when the integration record is saved
#   NS_TOKEN_ID        Access token (Setup > Users/Roles > Access Tokens)
#   NS_TOKEN_SECRET    shown ONCE when the access token is saved

NS_ACCOUNT_ID=
NS_CONSUMER_KEY=
NS_CONSUMER_SECRET=
NS_TOKEN_ID=
NS_TOKEN_SECRET=

# Optional: default File Cabinet folder internal id, used when --folder-id is
# omitted. There is intentionally no built-in default — pick a folder in your
# account (Documents > Files > File Cabinet, note the folder's internal id).
NS_DEFAULT_FOLDER_ID=

# Optional: override the RESTlet script/deployment ids if you changed them.
#NS_SCRIPT_ID=customscript_file_attach
#NS_DEPLOY_ID=customdeploy_file_attach
